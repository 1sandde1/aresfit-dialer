+      new Uint8Array(le32(0x02014b50)),new Uint8Array(le16(20)),new Uint8Array(le16(20)),new Uint8Array(le16(0)),new Uint8Array(le16(0)),
+      new Uint8Array(le16(time)),new Uint8Array(le16(day)),new Uint8Array(le32(crc)),new Uint8Array(le32(data.length)),new Uint8Array(le32(data.length)),
