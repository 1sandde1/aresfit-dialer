+  });
+  const centralStart=offset;
+  const central=concatBytes(centralParts);
+  const end=concatBytes([
+    new Uint8Array(le32(0x06054b50)),new Uint8Array(le16(0)),new Uint8Array(le16(0)),new Uint8Array(le16(files.length)),new Uint8Array(le16(files.length)),
